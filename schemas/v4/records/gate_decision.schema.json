      "type": "array"
    },
    "consumed_review_hashes": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Consumed Review Hashes",
      "type": "array"
    },
    "decision": {
      "enum": [
        "pass",
        "warn",
        "fail"
      ],
      "title": "Decision",
      "type": "string"
    },
    "findings": {
      "default": [],

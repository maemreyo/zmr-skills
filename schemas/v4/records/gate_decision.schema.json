    "invalidation_conditions": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Invalidation Conditions",
      "type": "array"
    },
    "policy_version": {
      "title": "Policy Version",
      "type": "string"
    },
    "record_id": {
      "title": "Record Id",
      "type": "string"

        "severity": {
          "default": "error",
          "enum": [
            "info",
            "warning",
            "error",
            "critical"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "Finding",
      "type": "object"
    }
  },
  "additionalProperties": false,

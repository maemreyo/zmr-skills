{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zamery.example/schemas/canonical-item.v3.json",
  "title": "Zamery Canonical Item V3",
  "type": "object",
  "required": [
    "schema_version", "item_id", "version", "status", "language", "grade_band",
    "cefr", "domain", "skill", "objective_ids", "interaction", "response_mode",
    "cognitive_operation", "difficulty", "stem", "answer", "rationale",
    "source_anchors", "tags"
  ],
  "properties": {
    "schema_version": {"const": "zamery-item.v3"},
    "item_id": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "status": {"enum": ["draft", "review", "approved", "retired"]},
    "difficulty": {"type": "number", "minimum": 0, "maximum": 1},
    "objective_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "source_anchors": {"type": "array", "minItems": 1},
    "answer": {"type": "object", "minProperties": 1}
  },
  "additionalProperties": true
}
